# MetaTrader 5 Credentials (NEW demo account for HFT testing)
MT5_LOGIN=your_hft_demo_login
MT5_PASSWORD=your_hft_demo_password
MT5_SERVER=your_broker_server_name
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# Symbol (auto-detected if left empty, common: XAUUSD, GOLD, XAUUSDm)
MT5_SYMBOL=XAUUSDm

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Trading Mode: demo or live
TRADING_MODE=demo

# Bot Identity
BOT_NAME=HFTBot
BOT_MAGIC=234567
